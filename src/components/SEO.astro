---
import { DEFAULT_LOCALE, LOCALES, routeForLocale, type Locale } from '../i18n/config';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  path: string;
  image?: string;
}

const { locale, title, description, path, image = '/og-image.png' } = Astro.props;
const site = 'https://iraiya.com';
const canonical = new URL(routeForLocale(locale, path), site).toString();
const imageUrl = new URL(image, site).toString();
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{LOCALES.map((alternateLocale) => (
  <link
    rel="alternate"
    hreflang={alternateLocale}
    href={new URL(routeForLocale(alternateLocale, path), site).toString()}
  />
))}
<link rel="alternate" hreflang="x-default" href={new URL(routeForLocale(DEFAULT_LOCALE, path), site).toString()} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Iraiya" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={imageUrl} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
<link rel="icon" type="image/png" href="/favicon.png" />
