---
import CTASection from '../../components/CTASection.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { services } from '../../data/services';
import { getDictionary } from '../../i18n';
import { isLocale, LOCALES, type Locale } from '../../i18n/config';
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
if (!isLocale(localeParam)) {
  throw new Error(`Unsupported locale: ${localeParam}`);
}
const locale: Locale = localeParam;
const t = getDictionary(locale);
---

<BaseLayout locale={locale} path="/services" title={t.pages.services.metaTitle} description={t.pages.services.metaDescription}>
  <section class="page-hero">
    <div class="site-shell">
      <h1>{t.pages.services.title}</h1>
      <p>{t.pages.services.description}</p>
    </div>
  </section>
  <section class="section-tight">
    <div class="site-shell">
      <div class="grid grid-3">
        {services.map((service) => <ServiceCard service={service} locale={locale} />)}
      </div>
    </div>
  </section>
  <CTASection locale={locale} />
</BaseLayout>
