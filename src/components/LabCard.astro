---
import type { Lab } from '../data/labs';
import type { Locale } from '../i18n/config';
import { getDictionary } from '../i18n';

interface Props {
  lab: Lab;
  locale: Locale;
}

const { lab, locale } = Astro.props;
const t = getDictionary(locale);
const statusLabel = lab.linkStatus === 'detail-page-only' ? t.common.linkReview : t.status[lab.status];
---

<article class:list={['lab-card', `lab-card-${lab.accent}`]}>
  <div class="lab-head">
    <span class:list={['badge', `badge-${lab.accent}`]}>{lab.category[locale]}</span>
    <span class="lab-status">{statusLabel}</span>
  </div>
  <h3>{lab.name}</h3>
  <p>{lab.description[locale]}</p>
  {lab.url ? (
    <a class="button" href={lab.url}>{t.common.openLink}</a>
  ) : (
    <span class="button button-disabled" aria-disabled="true">TODO</span>
  )}
</article>

<style>
  .lab-card {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    gap: 16px;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 22px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(250, 248, 241, 0.82)),
      repeating-linear-gradient(90deg, rgba(0, 143, 163, 0.045) 0 1px, transparent 1px 18px);
    box-shadow: 0 16px 40px rgba(22, 34, 34, 0.08);
  }

  .lab-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .lab-status {
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 800;
  }

  h3 {
    margin: 0;
    font-size: 1.45rem;
  }

  p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .button {
    width: fit-content;
    margin-top: auto;
  }
</style>
