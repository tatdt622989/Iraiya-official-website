---
import type { Service } from '../data/services';
import type { Locale } from '../i18n/config';

interface Props {
  service: Service;
  locale: Locale;
}

const { service, locale } = Astro.props;
---

<article class="service-card">
  <h3>{service.title[locale]}</h3>
  <p>{service.description[locale]}</p>
  <div class="service-detail">
    <strong>{service.suitableFor[locale]}</strong>
    <span>{service.solves[locale]}</span>
    <span>{service.deliverables[locale]}</span>
    <em>{service.start[locale]}</em>
  </div>
  <ul>
    {service.bullets[locale].map((bullet) => <li>{bullet}</li>)}
  </ul>
</article>

<style>
  .service-card {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    gap: 16px;
    border: 1px solid rgba(148, 163, 184, 0.16);
    border-radius: 8px;
    padding: 22px;
    background: rgba(16, 24, 39, 0.74);
  }

  h3 {
    margin: 0;
    font-size: 1.35rem;
  }

  p,
  span,
  em {
    margin: 0;
    color: #a8b4c4;
    line-height: 1.65;
  }

  .service-detail {
    display: grid;
    gap: 8px;
  }

  strong {
    color: #f8fafc;
    line-height: 1.55;
  }

  em {
    font-style: normal;
    color: #a5f3fc;
  }

  ul {
    display: grid;
    gap: 8px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  li {
    display: grid;
    grid-template-columns: 12px 1fr;
    gap: 8px;
    color: #cbd5e1;
    line-height: 1.5;
  }

  li::before {
    width: 8px;
    height: 8px;
    margin-top: 8px;
    border: 1px solid rgba(251, 191, 36, 0.65);
    border-radius: 2px;
    content: '';
  }
</style>
