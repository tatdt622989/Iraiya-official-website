---
import type { Lab } from '../data/labs';
import type { Locale } from '../i18n/config';
import { getDictionary } from '../i18n';

interface Props {
  lab: Lab;
  locale: Locale;
}

const { lab, locale } = Astro.props;
const t = getDictionary(locale);
const statusLabel = lab.linkStatus === 'detail-page-only' ? t.common.linkReview : t.status[lab.status];
---

<article class:list={['lab-card', `lab-card-${lab.accent}`]}>
  <div class="lab-head">
    <span class:list={['badge', `badge-${lab.accent}`]}>{lab.category[locale]}</span>
    <span class="lab-status">{statusLabel}</span>
  </div>
  <h3>{lab.name}</h3>
  <p>{lab.description[locale]}</p>
  {lab.url ? (
    <a class="button" href={lab.url}>{t.common.openLink}</a>
  ) : (
    <span class="button button-disabled" aria-disabled="true">TODO</span>
  )}
</article>

<style>
  .lab-card {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    gap: 16px;
    border: 1px solid rgba(148, 163, 184, 0.17);
    border-radius: 8px;
    padding: 22px;
    background:
      linear-gradient(180deg, rgba(20, 32, 51, 0.88), rgba(16, 24, 39, 0.82)),
      repeating-linear-gradient(90deg, rgba(148, 163, 184, 0.05) 0 1px, transparent 1px 18px);
  }

  .lab-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .lab-status {
    color: #94a3b8;
    font-size: 0.82rem;
    font-weight: 800;
  }

  h3 {
    margin: 0;
    font-size: 1.45rem;
  }

  p {
    margin: 0;
    color: #a8b4c4;
    line-height: 1.7;
  }

  .button {
    width: fit-content;
    margin-top: auto;
  }
</style>
