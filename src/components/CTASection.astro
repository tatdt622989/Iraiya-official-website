---
import { links } from '../data/links';
import { routeForLocale, type Locale } from '../i18n/config';
import { getDictionary } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDictionary(locale);
---

<section class="section">
  <div class="site-shell cta-band">
    <div>
      <h2>{t.common.contactIraiya}</h2>
      <p>{t.home.contactText}</p>
    </div>
    <div class="button-row">
      <a class="button button-primary" href={`mailto:${links.contactEmail}`}>{links.contactEmail}</a>
      <a class="button" href={routeForLocale(locale, '/contact')}>{t.common.learnMore}</a>
    </div>
  </div>
</section>

<style>
  .cta-band {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 24px;
    border: 1px solid rgba(34, 211, 238, 0.24);
    border-radius: 8px;
    padding: 28px;
    background:
      linear-gradient(100deg, rgba(34, 211, 238, 0.16), rgba(244, 63, 94, 0.08)),
      rgba(16, 24, 39, 0.78);
  }

  h2 {
    margin: 0 0 10px;
    font-size: clamp(1.7rem, 4vw, 2.6rem);
  }

  p {
    max-width: 720px;
    margin: 0;
    color: #cbd5e1;
    line-height: 1.7;
  }

  @media (max-width: 760px) {
    .cta-band {
      grid-template-columns: 1fr;
      padding: 22px;
    }
  }
</style>
