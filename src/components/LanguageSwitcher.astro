---
import { localeLabels, LOCALES, routeForLocale, type Locale } from '../i18n/config';

interface Props {
  locale: Locale;
  path: string;
}

const { locale, path } = Astro.props;
---

<label class="language-switcher">
  <span class="sr-only">Language</span>
  <select aria-label="Language" data-language-select>
    {LOCALES.map((availableLocale) => (
      <option value={routeForLocale(availableLocale, path)} selected={availableLocale === locale}>
        {localeLabels[availableLocale]}
      </option>
    ))}
  </select>
</label>

<script is:inline>
  document.querySelectorAll('[data-language-select]').forEach((select) => {
    select.addEventListener('change', (event) => {
      const value = event.currentTarget.value;
      if (value) window.location.href = value;
    });
  });
</script>

<style>
  .language-switcher {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .language-switcher::after {
    position: absolute;
    right: 11px;
    width: 7px;
    height: 7px;
    border-right: 2px solid #526263;
    border-bottom: 2px solid #526263;
    pointer-events: none;
    content: '';
    transform: translateY(-2px) rotate(45deg);
  }

  select {
    min-width: 116px;
    min-height: 40px;
    appearance: none;
    border: 1px solid rgba(23, 33, 38, 0.14);
    border-radius: 8px;
    padding: 8px 32px 8px 12px;
    background: rgba(255, 255, 255, 0.82);
    color: #172126;
    font: inherit;
    font-size: 0.84rem;
    font-weight: 800;
  }

  select:hover {
    border-color: rgba(0, 143, 163, 0.36);
  }

  @media (max-width: 420px) {
    select {
      min-width: 104px;
      min-height: 38px;
      font-size: 0.8rem;
    }
  }
</style>
