---
import { links } from '../data/links';
import type { Locale } from '../i18n/config';
import { getDictionary } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDictionary(locale);
const blogLinks = [
  { label: t.blogTopics.blog, href: links.blog },
  { label: t.blogTopics.ai, href: links.blogAi },
  { label: t.blogTopics.gameDev, href: links.blogGameDev },
  { label: t.blogTopics.japanese, href: links.blogJapanese },
  { label: t.blogTopics.frontend, href: links.blogFrontend }
];
---

<div class="blog-links">
  {blogLinks.map((item) => (
    <a class="blog-link" href={item.href}>
      <span>{item.label}</span>
      <span aria-hidden="true">↗</span>
    </a>
  ))}
</div>

<style>
  .blog-links {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
  }

  .blog-link {
    display: flex;
    min-height: 96px;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 16px;
    background: rgba(255, 255, 255, 0.78);
    color: var(--text);
    font-weight: 800;
    box-shadow: 0 14px 34px rgba(22, 34, 34, 0.07);
  }

  .blog-link span:last-child {
    color: var(--cyan);
  }

  .blog-link:hover {
    border-color: rgba(0, 143, 163, 0.32);
    background: rgba(255, 255, 255, 0.95);
  }

  @media (max-width: 900px) {
    .blog-links {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .blog-links {
      grid-template-columns: 1fr;
    }
  }
</style>
