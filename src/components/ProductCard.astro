---
import type { Product } from '../data/products';
import type { Locale } from '../i18n/config';
import { getDictionary } from '../i18n';

interface Props {
  product: Product;
  locale: Locale;
  detailed?: boolean;
}

const { product, locale, detailed = false } = Astro.props;
const t = getDictionary(locale);
const statusClassByStatus = {
  published: 'badge-green',
  'live-web-game': 'badge-cyan',
  'coming-soon': 'badge-gold',
  'in-development': 'badge-violet'
};
---

<article class:list={['product-card', `product-card-${product.accent}`, detailed && 'is-detailed']}>
  <div class="product-visual">
    <img src={product.image} alt="" loading="lazy" decoding="async" />
  </div>
  <div class="product-body">
    <div class="product-meta">
      <span class:list={['badge', statusClassByStatus[product.status]]}>{t.status[product.status]}</span>
      <span>{product.platform[locale]}</span>
    </div>
    <h3>{product.names[locale]}</h3>
    <p>{product.descriptions[locale]}</p>
    <dl>
      <div>
        <dt>{t.common.type}</dt>
        <dd>{product.type[locale]}</dd>
      </div>
      <div>
        <dt>{t.common.platform}</dt>
        <dd>{product.platform[locale]}</dd>
      </div>
    </dl>
    <ul class="tag-list" aria-label={t.common.topics}>
      {product.tags[locale].map((tag) => <li>{tag}</li>)}
    </ul>
    {product.notes[locale] && <p class="note">{product.notes[locale]}</p>}
    <div class="product-action">
      {product.url && product.ctaKind === 'link' ? (
        <a class="button" href={product.url}>{product.ctaLabel[locale]}</a>
      ) : (
        <span class="button button-disabled" aria-disabled="true">{product.ctaLabel[locale]}</span>
      )}
    </div>
  </div>
</article>

<style>
  .product-card {
    display: grid;
    min-height: 100%;
    grid-template-rows: auto 1fr;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.88);
    box-shadow: 0 20px 52px rgba(22, 34, 34, 0.1);
  }

  .product-card.is-detailed {
    grid-template-columns: minmax(260px, 0.46fr) 1fr;
    grid-template-rows: auto;
  }

  .product-visual {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #e8efe9;
  }

  .product-card.is-detailed .product-visual {
    min-height: 100%;
    aspect-ratio: auto;
  }

  .product-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 220ms ease;
  }

  .product-card:hover .product-visual img {
    transform: scale(1.025);
  }

  .product-body {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 20px;
  }

  .product-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    color: var(--muted);
    font-size: 0.85rem;
    font-weight: 700;
  }

  h3 {
    margin: 0;
    font-size: clamp(1.35rem, 2.5vw, 1.9rem);
    line-height: 1.18;
    color: var(--text);
  }

  p {
    margin: 0;
    color: var(--muted);
    line-height: 1.66;
  }

  dl {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin: 0;
  }

  dt {
    margin-bottom: 3px;
    color: #7d8b8b;
    font-size: 0.74rem;
    font-weight: 800;
  }

  dd {
    margin: 0;
    color: var(--text);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .note {
    border-left: 2px solid rgba(228, 164, 43, 0.55);
    padding-left: 10px;
    color: #657373;
    font-size: 0.86rem;
  }

  .product-action {
    margin-top: auto;
  }

  @media (max-width: 760px) {
    .product-card.is-detailed {
      grid-template-columns: 1fr;
      grid-template-rows: auto 1fr;
    }

    dl {
      grid-template-columns: 1fr;
    }
  }
</style>
