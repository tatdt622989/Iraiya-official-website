---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import SEO from '../components/SEO.astro';
import { localeHtmlLang, type Locale } from '../i18n/config';

interface Props {
  locale: Locale;
  path: string;
  title: string;
  description: string;
}

const { locale, path, title, description } = Astro.props;
---

<!doctype html>
<html lang={localeHtmlLang[locale]}>
  <head>
    <SEO locale={locale} path={path} title={title} description={description} />
  </head>
  <body>
    <Header locale={locale} path={path} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
