---
import { routeForLocale, type Locale } from '../i18n/config';
import { getDictionary } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDictionary(locale);
---

<section class="hero">
  <div class="site-shell hero-grid">
    <div class="hero-copy">
      <p class="hero-kicker">{t.brand.display}</p>
      <h1>{t.hero.title}</h1>
      <p class="hero-headline">{t.hero.headline}</p>
      <p class="hero-subtitle">{t.hero.subtitle}</p>
      <div class="button-row">
        <a class="button button-primary" href={routeForLocale(locale, '/apps')}>{t.common.viewApps}</a>
        <a class="button" href={routeForLocale(locale, '/labs')}>{t.common.exploreLabs}</a>
      </div>
    </div>
    <div class="hero-visual">
      <img
        src="/assets/hero-iraiya-studio.png"
        alt=""
        fetchpriority="high"
        decoding="async"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: clamp(42px, 7vh, 70px) 0 clamp(58px, 8vh, 84px);
    background:
      linear-gradient(90deg, rgba(0, 143, 163, 0.12), transparent 48%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(244, 247, 241, 0.1));
  }

  .hero-grid {
    display: grid;
    min-height: min(640px, calc(100svh - 120px));
    grid-template-columns: minmax(0, 0.94fr) minmax(380px, 1.06fr);
    align-items: center;
    gap: clamp(28px, 5vw, 58px);
  }

  .hero-copy {
    max-width: 680px;
  }

  .hero-kicker {
    width: fit-content;
    margin: 0 0 16px;
    border: 1px solid rgba(0, 143, 163, 0.22);
    border-radius: 999px;
    padding: 7px 12px;
    background: rgba(255, 255, 255, 0.74);
    color: #007b8d;
    font-size: 0.88rem;
    font-weight: 900;
  }

  .hero-copy h1 {
    margin: 0;
    max-width: 620px;
    font-size: clamp(3rem, 8vw, 6.4rem);
    line-height: 0.96;
    color: #172126;
  }

  .hero-headline {
    margin: 22px 0 0;
    color: #172126;
    font-size: clamp(1.3rem, 2.6vw, 2.05rem);
    font-weight: 800;
    line-height: 1.2;
  }

  .hero-subtitle {
    max-width: 650px;
    margin: 18px 0 30px;
    color: var(--muted);
    font-size: clamp(1rem, 2vw, 1.18rem);
    line-height: 1.72;
  }

  .hero-visual {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid rgba(23, 33, 38, 0.1);
    aspect-ratio: 1.12 / 1;
    background: #e5efe9;
    box-shadow: 0 28px 80px rgba(17, 37, 40, 0.18);
  }

  .hero-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-visual {
      max-height: 520px;
    }
  }

  @media (max-width: 600px) {
    .hero {
      padding: 34px 0 40px;
    }

    .hero-grid {
      gap: 26px;
      min-height: auto;
    }

    .hero-copy h1 {
      font-size: clamp(2.8rem, 13vw, 3.4rem);
    }

    .hero-headline {
      margin-top: 18px;
    }

    .hero-subtitle {
      margin-bottom: 22px;
      line-height: 1.62;
    }

    .hero-visual {
      aspect-ratio: 4 / 3;
    }
  }
</style>
