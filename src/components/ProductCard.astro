---
import type { Product } from '../data/products';
import type { Locale } from '../i18n/config';
import { getDictionary } from '../i18n';

interface Props {
  product: Product;
  locale: Locale;
  detailed?: boolean;
}

const { product, locale, detailed = false } = Astro.props;
const t = getDictionary(locale);
const statusClassByStatus = {
  published: 'badge-green',
  'live-web-game': 'badge-cyan',
  'coming-soon': 'badge-gold',
  'in-development': 'badge-violet'
};
---

<article class:list={['product-card', `product-card-${product.accent}`, detailed && 'is-detailed']}>
  <div class="product-visual">
    <img src={product.image} alt="" loading="lazy" decoding="async" />
  </div>
  <div class="product-body">
    <div class="product-meta">
      <span class:list={['badge', statusClassByStatus[product.status]]}>{t.status[product.status]}</span>
      <span>{product.platform[locale]}</span>
    </div>
    <h3>{product.names[locale]}</h3>
    <p>{product.descriptions[locale]}</p>
    <dl>
      <div>
        <dt>{t.common.type}</dt>
        <dd>{product.type[locale]}</dd>
      </div>
      <div>
        <dt>{t.common.platform}</dt>
        <dd>{product.platform[locale]}</dd>
      </div>
    </dl>
    <ul class="tag-list" aria-label={t.common.topics}>
      {product.tags[locale].map((tag) => <li>{tag}</li>)}
    </ul>
    {product.notes[locale] && <p class="note">{product.notes[locale]}</p>}
    <div class="product-action">
      {product.url && product.ctaKind === 'link' ? (
        <a class="button" href={product.url}>{product.ctaLabel[locale]}</a>
      ) : (
        <span class="button button-disabled" aria-disabled="true">{product.ctaLabel[locale]}</span>
      )}
    </div>
  </div>
</article>

<style>
  .product-card {
    display: grid;
    min-height: 100%;
    grid-template-columns: minmax(210px, 0.44fr) 1fr;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(20, 35, 56, 0.92), rgba(9, 20, 35, 0.92)),
      rgba(13, 24, 40, 0.9);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.28);
  }

  .product-card.is-detailed {
    grid-template-columns: minmax(310px, 0.48fr) 1fr;
  }

  .product-visual {
    position: relative;
    min-height: 100%;
    aspect-ratio: auto;
    overflow: hidden;
    background: #07111f;
  }

  .product-visual::after {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: '';
    background:
      linear-gradient(90deg, transparent 0%, rgba(7, 17, 31, 0.08) 62%, rgba(7, 17, 31, 0.58) 100%),
      inset 0 0 0 1px rgba(248, 250, 252, 0.04);
  }

  .product-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 220ms ease;
  }

  .product-card:hover .product-visual img {
    transform: scale(1.025);
  }

  .product-body {
    display: flex;
    flex-direction: column;
    gap: 13px;
    padding: clamp(20px, 2.4vw, 28px);
  }

  .product-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    color: var(--muted);
    font-size: 0.85rem;
    font-weight: 700;
  }

  h3 {
    margin: 0;
    font-size: clamp(1.35rem, 2.5vw, 1.9rem);
    line-height: 1.18;
    color: #f8fafc;
  }

  p {
    margin: 0;
    color: #aebccd;
    line-height: 1.66;
  }

  dl {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin: 0;
  }

  dt {
    margin-bottom: 3px;
    color: #718196;
    font-size: 0.74rem;
    font-weight: 800;
  }

  dd {
    margin: 0;
    color: #f8fafc;
    font-size: 0.92rem;
    font-weight: 700;
  }

  .note {
    border-left: 2px solid rgba(251, 191, 36, 0.55);
    padding-left: 10px;
    color: #cbd5e1;
    font-size: 0.86rem;
  }

  .product-action {
    margin-top: auto;
  }

  @media (max-width: 760px) {
    .product-card,
    .product-card.is-detailed {
      grid-template-columns: 1fr;
    }

    .product-visual {
      aspect-ratio: 16 / 10;
      min-height: 0;
    }

    dl {
      grid-template-columns: 1fr;
    }
  }
</style>
